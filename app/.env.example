# Pordee — Phase 0 environment
# Phase 0 still uses an in-memory finance store, so no DATABASE_URL is required yet.
# Better Auth uses a local SQLite file for user/session records until Postgres lands.

NODE_ENV=development
PORT=3000
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-a-random-production-secret
PORDEE_AUTH_DB_PATH=.data/auth.sqlite

# Phase 1 (uncomment when introducing Postgres):
# DATABASE_URL=postgres://pordee:pordee@localhost:5432/pordee
