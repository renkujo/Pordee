# Pordee — Phase 0 environment
# Phase 0 uses an in-memory mock store, so no DATABASE_URL is required yet.
# Variables listed here are placeholders for Phase 1 (Postgres + Drizzle).

NODE_ENV=development
PORT=3000

# Phase 1 (uncomment when introducing Postgres):
# DATABASE_URL=postgres://pordee:pordee@localhost:5432/pordee
# SESSION_SECRET=change-me
